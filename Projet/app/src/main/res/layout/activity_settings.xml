<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <Switch
        android:id="@+id/switchMusic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/enable_music"
        android:textSize="18sp"
        android:layout_marginBottom="24dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notification_preference"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <RadioGroup
        android:id="@+id/rgNotificationPref"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/rbTwoDays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/two_days_before" />

        <RadioButton
            android:id="@+id/rbOneWeek"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/one_week_before" />
    </RadioGroup>

</LinearLayout>